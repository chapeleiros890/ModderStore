# Copy this file to .env and fill in your values

# Server
PORT=3000

# Admin credentials (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=modder21admin

# JWT secret (use a long random string)
JWT_SECRET=change_this_to_a_long_random_secret_string_1234567890

# Discord webhook URL (optional - for order notifications)
# Get this from: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# Store name (shown in emails/notifications)
STORE_NAME=Modder21 Store
